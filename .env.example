# Groq-ключи для бесплатного AI (через запятую, ротация). НЕ коммитьте в git!
GROQ_KEYS=gsk_xxx,gsk_yyy,gsk_zzz

# Модель по умолчанию и белый список (через запятую)
GROQ_FREE_MODEL=llama-3.1-8b-instant
GROQ_FREE_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile,llama-3.1-70b-versatile,gemma2-9b-it

# Лимит бесплатных запросов на IP+fingerprint в час
LZT_FREE_AI_LIMIT=15

# Fingerprint клиента (по умолчанию LZTConstruct/<версия>)
# LZT_CLIENT_FP=LZTConstruct/1.0.0

# URL прокладки — только в backend/local_build.py при сборке .exe (файл в .gitignore)
# или в .env для локальной разработки:
# LZT_PUBLIC_FREE_AI_URL=https://your-vps.example/api/ai/free
# LZT_FREE_AI_URL=https://your-vps.example/api/ai/free

# CORS для публичной прокладки (* — разрешить все origin)
# LZT_CORS=*
